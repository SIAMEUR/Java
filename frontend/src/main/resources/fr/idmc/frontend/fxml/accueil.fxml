<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<VBox styleClass="root-accueil"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="fr.idmc.frontend.controller.AccueilController">

    <HBox styleClass="header" alignment="CENTER_LEFT">
        <Label text="Lunettes connectées IDMC" styleClass="header-titre"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statutConnexion" styleClass="header-statut"/>
    </HBox>

    <VBox alignment="CENTER" spacing="22" styleClass="contenu" VBox.vgrow="ALWAYS">
        <Label text="Bienvenue" styleClass="titre"/>
        <Label text="Plateforme de commande et de suivi de lunettes connectées." styleClass="sous-titre"/>

        <VBox alignment="CENTER" spacing="12">
            <Button text="Passer une commande" styleClass="btn-principal" onAction="#allerCommande" prefWidth="280"/>
            <Button text="Suivre mes commandes" styleClass="btn-secondaire" onAction="#allerLivraison" prefWidth="280"/>
            <Button text="Vérifier un numéro de série" styleClass="btn-secondaire" onAction="#allerVerification" prefWidth="280"/>
        </VBox>
    </VBox>

    <HBox styleClass="footer" alignment="CENTER_LEFT">
        <Label fx:id="footerInfo" styleClass="footer-info"/>
    </HBox>

</VBox>
